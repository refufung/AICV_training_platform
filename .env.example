# ============================================================
# Environment Variables — Copy to .env and fill in values
# cp .env.example .env
# ============================================================

# PostgreSQL + PostGIS
DATABASE_URL=postgresql://postgres:password@localhost:5432/bim_defects

# JWT Auth
JWT_SECRET_KEY=your-secret-key-change-this-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=480

# File Storage
UPLOAD_DIR=backend/uploads

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# IFC Files (paths to your IFC models)
IFC_FILE_1=EMSDN-EMS-NA_BD-K1_01-AR-M3_A_2024 - BD5 - window .ifc
IFC_FILE_2=EMSDN-EMS-NA_BD-K1_01-BS_LG-M3_A_2024 - BEC R4.ifc
